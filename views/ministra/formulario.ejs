<div class="row page-titles mx-0">
    <div class="col-sm-6 p-md-0">
        <div class="welcome-text">
            <h4><%= titulo %></h4>
        </div>
    </div>
    <div class="col-sm-6 p-md-0 justify-content-sm-end mt-2 mt-sm-0 d-flex">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Inicial</a></li>
            <li class="breadcrumb-item"><a href="/ministra">Prof. por Turma</a></li>
            <li class="breadcrumb-item active"><a href="javascript:void(0)"><%= titulo %></a></li>
        </ol>
    </div>
</div>

<div class="row">
    <div class="col-lg-12">
        <div class="card">
            <div class="card-body">
                <form action="/ministra/vincular" method="POST">
                    <div class="form-group row">
                        <label class="col-sm-3 col-form-label">Turma</label>
                        <div class="col-sm-9">
                            <select class="form-control" name="turmaId" required>
                                <option value="">Selecione...</option>
                                <% turmas.forEach(t => { %>
                                    <option value="<%= t.id %>"><%= t.nome %></option>
                                <% }) %>
                            </select>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-sm-3 col-form-label">Professor</label>
                        <div class="col-sm-9">
                            <select class="form-control" name="professorId" required>
                                <option value="">Selecione...</option>
                                <% professores.forEach(p => { %>
                                    <option value="<%= p.id %>"><%= p.nome %></option>
                                <% }) %>
                            </select>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-sm-3 col-form-label">Data de Atribuição</label>
                        <div class="col-sm-9">
                            <input type="date" class="form-control" name="dataAtribuicao" required>
                        </div>
                    </div>
                    <div class="form-group row">
                        <div class="col-sm-9 offset-sm-3">
                            <button type="submit" class="btn btn-primary">Salvar</button>
                            <a href="/ministra" class="btn btn-light ml-2">Cancelar</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
