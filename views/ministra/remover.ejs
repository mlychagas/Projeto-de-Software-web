<% vinculo = locals.vinculo || {}; %>
<div class="row page-titles mx-0">
    <div class="col-sm-6 p-md-0">
        <div class="welcome-text">
            <h4><%= locals.titulo %></h4>
            <p class="mb-0">&raquo; <%= locals.subtitulo %></p>
        </div>
    </div>
    <div class="col-sm-6 p-md-0 justify-content-sm-end mt-2 mt-sm-0 d-flex">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Inicial</a></li>
            <li class="breadcrumb-item active"><a href="/ministra">Consultar Vínculos</a></li>
            <li class="breadcrumb-item active"><a href="javascript:void(0)">Remover Vínculo</a></li>
        </ol>
    </div>
</div>

<div class="row">
    <div class="col-lg-8 offset-lg-2">
        <div class="card border-danger">
            <div class="card-header bg-danger">
                <h4 class="card-title text-white mb-0">Remoção de Vínculo Professor/Turma</h4>
            </div>
            <div class="card-body">
                <% if (locals.erro) { %>
                    <div class="alert alert-danger">
                        <strong>Não foi possível remover:</strong> <%= locals.erro %>
                    </div>
                <% } else { %>
                    <div class="alert alert-warning">
                        Esta ação é irreversível. Tem certeza que deseja remover o vínculo do professor <strong><%= vinculo.professor ? vinculo.professor.nome : '' %></strong> com a turma <strong><%= vinculo.turma ? vinculo.turma.nome : '' %></strong>?
                    </div>
                <% } %>
                <div class="table-responsive mb-4">
                    <table class="table table-bordered mb-0">
                        <tbody>
                            <tr>
                                <th>Professor</th>
                                <td><%= vinculo.professor ? vinculo.professor.nome : '-' %></td>
                            </tr>
                            <tr>
                                <th>Turma</th>
                                <td><%= vinculo.turma ? vinculo.turma.nome : '-' %></td>
                            </tr>
                            <tr>
                                <th>Data de Atribuição</th>
                                <td><%= dateFormat(vinculo.dataAtribuicao) %></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <% if (!locals.erro) { %>
                    <form action="/ministra/<%= vinculo.turma ? vinculo.turma.id : '' %>/<%= vinculo.professor ? vinculo.professor.id : '' %>/excluir" method="POST">
                        <button type="submit" class="btn btn-danger mr-2">Remover Vínculo</button>
                        <a href="/ministra" class="btn btn-warning">Cancelar</a>
                    </form>
                <% } else { %>
                    <a href="/ministra" class="btn btn-warning">Voltar</a>
                <% } %>
            </div>
        </div>
    </div>
</div>
