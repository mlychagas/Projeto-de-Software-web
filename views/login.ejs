<style>
    .login-container {
        display: flex;
        height: 100vh;
        width: 100vw;
    }
    .login-left {
        flex: 1;
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 2rem 4rem;
        background: radial-gradient(120% 85% at 100% -10%, #E5EDF4 0%, transparent 52%), 
                    radial-gradient(90% 60% at 0% 110%, #EFEFFA 0%, transparent 55%), 
                    linear-gradient(180deg, #F4F6FB, #FFFFFF);
        position: relative;
    }
    .login-right {
        display: none;
        flex: 1;
        background-color: #fff;
        padding: 1.5rem;
    }
    @media (min-width: 992px) {
        .login-right {
            display: flex;
        }
    }
    .login-image-wrapper {
        width: 100%;
        height: 100%;
        border-radius: 32px;
        overflow: hidden;
        position: relative;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    }
    .login-image-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    .login-image-overlay {
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background-color: rgba(0,0,0,0.1);
        mix-blend-mode: overlay;
    }
    .login-form-wrapper {
        width: 100%;
        max-width: 400px;
        margin: 0 auto;
    }
    .login-header {
        margin-bottom: 2rem;
    }
    .login-logo {
        width: 64px;
        height: 64px;
        background-color: #111827;
        color: white;
        border-radius: 16px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        font-weight: bold;
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        margin-bottom: 1.25rem;
    }
    .login-title {
        font-size: 32px;
        font-weight: 700;
        color: #0f172a;
        margin-bottom: 0.5rem;
        letter-spacing: -0.025em;
    }
    .login-subtitle {
        color: #475569;
        font-size: 15px;
        line-height: 1.6;
    }
    .form-group label {
        display: block;
        font-size: 14px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #475569;
        margin-bottom: 0.375rem;
    }
    .form-control-custom {
        width: 100%;
        height: 48px;
        background-color: #F7FBFF;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 0 1rem;
        font-size: 15px;
        color: #0f172a;
        transition: all 0.2s;
    }
    .form-control-custom:focus {
        outline: none;
        border-color: #593bdb;
        box-shadow: 0 0 0 3px rgba(89, 59, 219, 0.1);
    }
    .btn-login {
        width: 100%;
        height: 48px;
        background-color: #111827;
        color: white;
        border: none;
        border-radius: 12px;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        transition: opacity 0.2s;
        margin-top: 1rem;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }
    .btn-login:hover {
        opacity: 0.9;
    }
    .forgot-link {
        display: flex;
        justify-content: flex-end;
        margin-top: 0.5rem;
    }
    .forgot-link a {
        color: #2563eb;
        font-size: 14px;
        text-decoration: none;
    }
    .forgot-link a:hover {
        text-decoration: underline;
    }
    .error-alert {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        background-color: #fef2f2;
        border: 1px solid #fee2e2;
        color: #dc2626;
        padding: 0.75rem 1rem;
        border-radius: 12px;
        font-size: 14px;
        margin-bottom: 1.5rem;
    }
    .login-footer {
        position: absolute;
        bottom: 2rem;
        left: 2rem;
        color: #94a3b8;
        font-size: 12px;
        font-weight: 500;
        letter-spacing: 0.025em;
    }
</style>

<div class="login-container">
    <div class="login-left">
        <div class="login-form-wrapper">
            <div class="login-header">
                <div class="login-logo">M</div>
                <h1 class="login-title">MuseERP</h1>
                <p class="login-subtitle">Faça login para gerenciar sua escola de música.</p>
            </div>

            <% if (typeof error !== 'undefined' && error) { %>
                <div class="error-alert">
                    <svg style="width: 20px; height: 20px; flex-shrink: 0;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                    </svg>
                    <span><%= error %></span>
                </div>
            <% } %>

            <form action="/auth/login" method="POST">
                <div class="form-group mb-3">
                    <label for="email">E-mail</label>
                    <input type="email" name="email" id="email" class="form-control-custom" placeholder="Seu e-mail de acesso" required>
                </div>
                
                <div class="form-group mb-2">
                    <label for="password">Senha</label>
                    <input type="password" name="password" id="password" class="form-control-custom" placeholder="Sua senha" required>
                    <div class="forgot-link">
                        <a href="javascript:alert('Contate o suporte técnico para redefinir sua senha.')">Esqueci a Senha</a>
                    </div>
                </div>

                <button type="submit" class="btn-login">Acessar Painel</button>
            </form>
        </div>

        <div class="login-footer">
            Desenvolvido por MuseERP &copy; 2026
        </div>
    </div>

    <div class="login-right">
        <div class="login-image-wrapper">
            <img src="/images/loginArt.png" alt="Música e Gestão">
            <div class="login-image-overlay"></div>
        </div>
    </div>
</div>
