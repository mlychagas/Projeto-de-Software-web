<div class="row">
    <!-- COLUNA 1: Métricas (Donut Charts) -->
    <div class="col-lg-2 col-md-12 text-center">
        <!-- Cursos -->
        <div class="mb-3">
            <h6 class="text-muted text-uppercase mb-2" style="font-size: 11px;">Cursos</h6>
            <div class="donut-chart" style="background: conic-gradient(#3498db 0% <%= cursoTopPercent %>%, #e67e22 <%= cursoTopPercent %>% 100%);">
                <div class="donut-content">
                    <div class="label"><%= cursoTopTotal %> Matric.</div>
                    <div class="value"><%= cursoTopPercent %>%</div>
                    <div class="label" style="font-size: 9px; line-height: 1.2;"><%= cursoTopNome %></div>
                </div>
            </div>
        </div>

        <!-- Aulas Dia -->
        <div class="mb-3">
            <h6 class="text-muted text-uppercase mb-2" style="font-size: 11px;">Aulas Dia</h6>
            <div class="donut-chart" style="background: conic-gradient(#f368e0 0% <%= percentAulasRealizadas %>%, #48dbfb <%= percentAulasRealizadas %>% 100%);">
                <div class="donut-content">
                    <div class="label"><%= aulasHoje %> Aulas</div>
                    <div class="value"><%= percentAulasRealizadas %>%</div>
                    <div class="label">Realizadas</div>
                </div>
            </div>
        </div>

        <!-- Presença Hoje -->
        <div class="mb-3">
            <h6 class="text-muted text-uppercase mb-2" style="font-size: 11px;">Presença Hoje</h6>
            <div class="donut-chart" style="background: conic-gradient(#f1c40f 0% <%= percentPresencaHoje %>%, #f4f6f9 <%= percentPresencaHoje %>% 100%);">
                <div class="donut-content">
                    <div class="label"><%= presencasHoje %> Pres.</div>
                    <div class="value"><%= percentPresencaHoje %>%</div>
                    <div class="label"><%= aulasHoje %> Presenças</div>
                </div>
            </div>
        </div>

        <!-- Presença Ontem -->
        <div class="mb-3">
            <h6 class="text-muted text-uppercase mb-2" style="font-size: 11px;">Presença Ontem</h6>
            <div class="donut-chart" style="background: conic-gradient(#e67e22 0% <%= percentPresencaOntem %>%, #f4f6f9 <%= percentPresencaOntem %>% 100%);">
                <div class="donut-content">
                    <div class="label"><%= presencasOntem %> Pres.</div>
                    <div class="value"><%= percentPresencaOntem %>%</div>
                    <div class="label"><%= totalAulasOntem %> Presenças</div>
                </div>
            </div>
        </div>
    </div>

    <!-- COLUNA 2: Aulas em Andamento e Próximas Aulas -->
    <div class="col-lg-7 col-md-12">
        <!-- Aulas em Andamento -->
        <div class="theme-card">
            <h4 class="theme-card-title mb-0 border-0">Aulas em Andamento</h4>
            <div class="custom-scroll-area">
                <table class="table table-aulas mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th>Hora</th>
                            <th>Aluno / Professor</th>
                            <th class="text-center">Presença</th>
                            <th>Sala</th>
                            <th class="text-center">Faltas</th>
                            <th class="text-center">Faturas</th>
                            <th class="text-center">Venc.</th>
                            <th class="text-center">Contrato</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (aulasEmAndamento && aulasEmAndamento.length > 0) { %>
                            <% aulasEmAndamento.forEach(aula => { %>
                                <tr>
                                    <td><%= aula.horario %></td>
                                    <td>
                                        <div class="avatar-cell">
                                            <img src="/images/avatar/1.png" alt="<%= aula.alunoNome %>">
                                            <div class="stacked-names">
                                                <span class="primary-name"><i class="mdi mdi-music-note text-warning"></i> <%= aula.alunoNome %></span>
                                                <span class="secondary-name"><i class="mdi mdi-account"></i> <%= aula.professorNome %></span>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center"><i class="mdi mdi-square-edit-outline edit-icon-btn"></i></td>
                                    <td><%= aula.salaNome %></td>
                                    <td class="text-center">
                                        <span class="circle-badge <%= aula.totalFaltas > 5 ? 'bg-light-red' : 'bg-light-orange' %>"><%= aula.totalFaltas %></span>
                                    </td>
                                    <td class="text-center">
                                        <span class="circle-badge <%= aula.faturasAbertas > 0 ? 'bg-light-yellow' : 'bg-light-green' %>"><%= aula.faturasAbertas %></span>
                                    </td>
                                    <td class="text-center">
                                        <span class="circle-badge bg-light-green"><%= aula.vencimentoLabel %></span>
                                    </td>
                                    <td class="text-center"><i class="mdi mdi-alert text-warning-icon"></i></td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="8" class="text-center text-muted py-3">Nenhuma aula em andamento no momento.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Próximas Aulas -->
        <div class="theme-card mt-4">
            <h4 class="theme-card-title mb-0 border-0">Próximas Aulas</h4>
            <div class="custom-scroll-area">
                <table class="table table-aulas mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th>Hora</th>
                            <th>Aluno / Professor</th>
                            <th class="text-center">Presença</th>
                            <th>Sala</th>
                            <th class="text-center">Faltas</th>
                            <th class="text-center">Faturas</th>
                            <th class="text-center">Venc.</th>
                            <th class="text-center">Contrato</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (proximasAulas && proximasAulas.length > 0) { %>
                            <% proximasAulas.forEach(aula => { %>
                                <tr>
                                    <td><%= aula.horario %></td>
                                    <td>
                                        <div class="avatar-cell">
                                            <img src="/images/avatar/1.png" alt="<%= aula.alunoNome %>">
                                            <div class="stacked-names">
                                                <span class="primary-name"><i class="mdi mdi-music-note text-warning"></i> <%= aula.alunoNome %></span>
                                                <span class="secondary-name"><i class="mdi mdi-account"></i> <%= aula.professorNome %></span>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center"><i class="mdi mdi-square-edit-outline edit-icon-btn"></i></td>
                                    <td><%= aula.salaNome %></td>
                                    <td class="text-center">
                                        <span class="circle-badge <%= aula.totalFaltas > 5 ? 'bg-light-red' : 'bg-light-orange' %>"><%= aula.totalFaltas %></span>
                                    </td>
                                    <td class="text-center">
                                        <span class="circle-badge <%= aula.faturasAbertas > 0 ? 'bg-light-yellow' : 'bg-light-green' %>"><%= aula.faturasAbertas %></span>
                                    </td>
                                    <td class="text-center">
                                        <span class="circle-badge bg-light-green"><%= aula.vencimentoLabel %></span>
                                    </td>
                                    <td class="text-center"><i class="mdi mdi-alert text-warning-icon"></i></td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="8" class="text-center text-muted py-3">Nenhuma próxima aula agendada para hoje.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- COLUNA 3: Anotações -->
    <div class="col-lg-3 col-md-12">
        <div class="theme-card h-100 p-0">
            <h4 class="theme-card-title p-3 m-0" style="border-bottom: none;">
                Anotações
                <button class="btn btn-outline-primary btn-sm rounded"><i class="mdi mdi-plus-box-outline"></i> Nova Anotação</button>
            </h4>
            <div class="custom-scroll-area-lg">
                <table class="table table-bordered mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th style="width: 30%;">Data</th>
                            <th>Aviso</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (anotacoes && anotacoes.length > 0) { %>
                            <% anotacoes.forEach(registro => { %>
                                <tr>
                                    <td style="height: 40px;"><%= dateFormat(registro.dataHora, { day: '2-digit', month: '2-digit' }) %></td>
                                    <td>
                                        <small>
                                            <strong><%= registro.tipoRegistro %></strong>
                                            <% if (registro.aluno) { %>
                                                - <%= registro.aluno.nome %>
                                            <% } %>
                                            <br><%= registro.descricao ? registro.descricao.substring(0, 80) : '' %>
                                        </small>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="2" class="text-center text-muted py-3">Nenhuma anotação registrada.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>