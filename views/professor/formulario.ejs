<div class="row page-titles mx-0">
    <div class="col-sm-6 p-md-0">
        <div class="welcome-text">
            <h4><%= titulo %></h4>
        </div>
    </div>
    <div class="col-sm-6 p-md-0 justify-content-sm-end mt-2 mt-sm-0 d-flex">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Inicial</a></li>
            <li class="breadcrumb-item"><a href="/escola/professores">Professores</a></li>
            <li class="breadcrumb-item active"><a href="javascript:void(0)"><%= titulo %></a></li>
        </ol>
    </div>
</div>

<div class="row">
    <div class="col-lg-12">
        <div class="card">
            <div class="card-header">
                <h4 class="card-title">Dados do Professor</h4>
            </div>
            <div class="card-body">
                <form action="<%= professor && professor.id ? '/escola/professores/' + professor.id + '/editar' : '/escola/professores/criar' %>" method="POST">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Nome Completo *</label>
                                <input type="text" class="form-control" name="nome" value="<%= professor ? professor.nome : '' %>" required>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>E-mail</label>
                                <input type="email" class="form-control" name="email" value="<%= professor ? (professor.email || '') : '' %>">
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>CPF</label>
                                <input type="text" class="form-control" name="cpf" value="<%= professor ? (professor.cpf || '') : '' %>" maxlength="11" placeholder="Apenas números">
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>RG</label>
                                <input type="text" class="form-control" name="rg" value="<%= professor ? (professor.rg || '') : '' %>">
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>Telefone</label>
                                <input type="text" class="form-control" name="telefone" value="<%= professor ? (professor.telefone || '') : '' %>" placeholder="(00) 00000-0000">
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>Data de Nascimento</label>
                                <input type="date" class="form-control" name="dataNascimento" value="<%= professor && professor.dataNascimento ? new Date(professor.dataNascimento).toISOString().split('T')[0] : '' %>">
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>Data de Admissão</label>
                                <input type="date" class="form-control" name="dataAdmissao" value="<%= professor && professor.dataAdmissao ? new Date(professor.dataAdmissao).toISOString().split('T')[0] : '' %>">
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>Status</label>
                                <select class="form-control" name="statusProf">
                                    <% ['Ativo','Inativo','Afastado','Desligado'].forEach(s => { %>
                                        <option value="<%= s %>" <%= professor && professor.statusProf === s ? 'selected' : '' %>><%= s %></option>
                                    <% }) %>
                                </select>
                            </div>
                        </div>
                    </div>

                    <hr>
                    <h5 class="mb-3"><i class="mdi mdi-music-note mr-1"></i> Informações Pedagógicas</h5>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Especialidade / Instrumento Principal</label>
                                <input type="text" class="form-control" name="especialidade" value="<%= professor ? (professor.especialidade || '') : '' %>" placeholder="Ex: Violão, Piano, Canto...">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Valor Hora/Aula (R$)</label>
                                <input type="number" class="form-control" name="valorHoraAula" step="0.01" min="0" value="<%= professor && professor.valorHoraAula ? professor.valorHoraAula : '' %>" placeholder="0.00">
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Observações</label>
                        <textarea class="form-control" name="observacoes" rows="3" placeholder="Observações internas sobre o professor..."><%= professor ? (professor.observacoes || '') : '' %></textarea>
                    </div>

                    <div class="form-group mt-4">
                        <button type="submit" class="btn btn-primary">Salvar Professor</button>
                        <a href="/escola/professores" class="btn btn-light ml-2">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
