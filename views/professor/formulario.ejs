<div class="row page-titles mx-0">
    <div class="col-sm-6 p-md-0">
        <div class="welcome-text">
            <h4><%= titulo %></h4>
        </div>
    </div>
    <div class="col-sm-6 p-md-0 justify-content-sm-end mt-2 mt-sm-0 d-flex">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Inicial</a></li>
            <li class="breadcrumb-item"><a href="/professores">Professores</a></li>
            <li class="breadcrumb-item active"><a href="javascript:void(0)"><%= titulo %></a></li>
        </ol>
    </div>
</div>

<div class="row">
    <div class="col-lg-12">
        <div class="card">
            <div class="card-body">
                <form action="/professores/<%= professor && professor.id ? professor.id + '/editar' : 'criar' %>" method="POST">
                    <div class="form-group row">
                        <label class="col-sm-3 col-form-label">Nome</label>
                        <div class="col-sm-9">
                            <input type="text" class="form-control" name="nome" value="<%= professor ? professor.nome : '' %>" required>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-sm-3 col-form-label">CPF</label>
                        <div class="col-sm-9">
                            <input type="text" class="form-control" name="cpf" maxlength="11" value="<%= professor ? professor.cpf : '' %>" required>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-sm-3 col-form-label">RG</label>
                        <div class="col-sm-9">
                            <input type="text" class="form-control" name="rg" maxlength="20" value="<%= professor ? professor.rg : '' %>" required>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-sm-3 col-form-label">E-mail</label>
                        <div class="col-sm-9">
                            <input type="email" class="form-control" name="email" value="<%= professor ? (professor.email || '') : '' %>">
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-sm-3 col-form-label">Telefone</label>
                        <div class="col-sm-9">
                            <input type="text" class="form-control" name="telefone" value="<%= professor ? professor.telefone : '' %>" required>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-sm-3 col-form-label">Especialidade</label>
                        <div class="col-sm-9">
                            <input type="text" class="form-control" name="especialidade" value="<%= professor ? professor.especialidade : '' %>" required>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-sm-3 col-form-label">Valor/Hora (R$)</label>
                        <div class="col-sm-9">
                            <input type="text" class="form-control" name="valorHoraAula" value="<%= professor ? String(professor.valorHoraAula).replace('.', ',') : '0,00' %>" required>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-sm-3 col-form-label">Data de Admissão</label>
                        <div class="col-sm-9">
                            <input type="date" class="form-control" name="dataAdmissao" value="<%= professor ? professor.dataAdmissao : '' %>" required>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-sm-3 col-form-label">Data de Demissão</label>
                        <div class="col-sm-9">
                            <input type="date" class="form-control" name="dataDemissao" value="<%= professor ? (professor.dataDemissao || '') : '' %>">
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-sm-3 col-form-label">Status</label>
                        <div class="col-sm-9">
                            <select class="form-control" name="statusProf">
                                <% ['Ativo','Inativo','Afastado','Desligado'].forEach(s => { %>
                                    <option value="<%= s %>" <%= professor && professor.statusProf === s ? 'selected' : '' %>><%= s %></option>
                                <% }) %>
                            </select>
                        </div>
                    </div>
                    <div class="form-group row">
                        <div class="col-sm-9 offset-sm-3">
                            <button type="submit" class="btn btn-primary">Salvar</button>
                            <a href="/professores" class="btn btn-light ml-2">Cancelar</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
