<div class="row page-titles mx-0">
    <div class="col-sm-6 p-md-0">
        <div class="welcome-text">
            <h4><%= titulo %></h4>
            <p class="mb-0">&raquo; Consulte todas as pessoas cadastradas no sistema</p>
        </div>
    </div>
    <div class="col-sm-6 p-md-0 justify-content-sm-end mt-2 mt-sm-0 d-flex">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Inicial</a></li>
            <li class="breadcrumb-item active"><a href="javascript:void(0)">Pessoas</a></li>
        </ol>
    </div>
</div>

<div class="row">
    <div class="col-lg-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <div class="basic-form">
                    <form>
                        <div class="form-row">
                            <div class="col-auto">
                                <input type="text" class="form-control" placeholder="Digite para pesquisar...">
                            </div>
                            <div class="col-auto mt-2 mt-lg-0">
                                <button type="submit" class="btn btn-primary mb-2">Pesquisar</button>
                            </div>
                        </div>
                    </form>
                </div>
                <a href="/pessoas/criar" class="btn btn-success">Novo</a>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-responsive-sm">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Nome</th>
                                <th>CPF</th>
                                <th>Responsável</th>
                                <th>Matrícula</th>
                                <th>Status</th>
                                <th>Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% for (let i = 0; i < pessoas.length; i++) { %>
                                <tr>
                                    <td><%= i + 1 %></td>
                                    <td><%= pessoas[i].nome %></td>
                                    <td><%= pessoas[i].cpf || '-' %></td>
                                    <td><%= pessoas[i].responsavel ? pessoas[i].responsavel.nome : '-' %></td>
                                    <td><%= pessoas[i].dataMatricula ? new Date(pessoas[i].dataMatricula).toLocaleDateString('pt-BR') : '-' %></td>
                                    <td>
                                        <% if (pessoas[i].statusAluno === 'Ativo' || pessoas[i].statusProf === 'Ativo') { %>
                                            <span class="badge badge-primary"><%= pessoas[i].statusAluno || pessoas[i].statusProf %></span>
                                        <% } else { %>
                                            <span class="badge badge-danger"><%= pessoas[i].statusAluno || pessoas[i].statusProf || 'Inativo' %></span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <a href="/pessoas/<%= pessoas[i].id %>/perfil" class="text-primary mr-2" title="Ver Perfil">
                                            <i class="fa fa-user fa-lg"></i>
                                        </a>
                                        <a href="/pessoas/<%= pessoas[i].id %>/editar" class="text-warning mr-2">
                                            <i class="fa fa-pencil fa-lg"></i>
                                        </a>
                                        <a href="/pessoas/<%= pessoas[i].id %>/excluir" class="text-danger">
                                            <i class="fa fa-trash fa-lg"></i>
                                        </a>
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
