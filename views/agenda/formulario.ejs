<div class="row page-titles mx-0">
    <div class="col-sm-6 p-md-0">
        <div class="welcome-text">
            <h4><%= titulo %></h4>
        </div>
    </div>
    <div class="col-sm-6 p-md-0 justify-content-sm-end mt-2 mt-sm-0 d-flex">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Inicial</a></li>
            <li class="breadcrumb-item"><a href="/agenda">Agenda</a></li>
            <li class="breadcrumb-item active"><a href="javascript:void(0)"><%= titulo %></a></li>
        </ol>
    </div>
</div>

<div class="row">
    <div class="col-lg-12">
        <div class="card">
            <div class="card-body">
                <form action="/agenda/<%= matricula ? matricula.fkAlunoId + '/' + matricula.fkTurmaId + '/editar' : 'matricular' %>" method="POST">
                    <div class="form-group row">
                        <label class="col-sm-3 col-form-label">Aluno</label>
                        <div class="col-sm-9">
                            <select class="form-control" name="alunoId" <%= matricula ? 'disabled' : 'required' %>>
                                <option value="">Selecione...</option>
                                <% alunos.forEach(a => { %>
                                    <option value="<%= a.id %>" <%= matricula && matricula.fkAlunoId === a.id ? 'selected' : '' %>><%= a.nome %></option>
                                <% }) %>
                            </select>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-sm-3 col-form-label">Turma</label>
                        <div class="col-sm-9">
                            <select class="form-control" name="turmaId" <%= matricula ? 'disabled' : 'required' %>>
                                <option value="">Selecione...</option>
                                <% turmas.forEach(t => { %>
                                    <option value="<%= t.id %>" <%= matricula && matricula.fkTurmaId === t.id ? 'selected' : '' %>><%= t.nome %></option>
                                <% }) %>
                            </select>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-sm-3 col-form-label">Data de Inscrição</label>
                        <div class="col-sm-9">
                            <input type="date" class="form-control" name="dataInscricao" value="<%= matricula ? matricula.dataInscricao : '' %>" required>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-sm-3 col-form-label">Frequência</label>
                        <div class="col-sm-9">
                            <input type="number" class="form-control" name="frequencia" value="<%= matricula ? matricula.frequencia : 0 %>" min="0">
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-sm-3 col-form-label">Status</label>
                        <div class="col-sm-9">
                            <select class="form-control" name="statusAgenda">
                                <% ['Matriculado','Cancelado','Suspenso','Concluído'].forEach(s => { %>
                                    <option value="<%= s %>" <%= matricula && matricula.statusAgenda === s ? 'selected' : '' %>><%= s %></option>
                                <% }) %>
                            </select>
                        </div>
                    </div>
                    <div class="form-group row">
                        <div class="col-sm-9 offset-sm-3">
                            <button type="submit" class="btn btn-primary">Salvar</button>
                            <a href="/agenda" class="btn btn-light ml-2">Cancelar</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
