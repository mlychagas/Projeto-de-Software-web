<div class="row page-titles mx-0">
    <div class="col-sm-6 p-md-0">
        <div class="welcome-text">
            <h4><%= titulo %></h4>
        </div>
    </div>
    <div class="col-sm-6 p-md-0 justify-content-sm-end mt-2 mt-sm-0 d-flex">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Inicial</a></li>
            <li class="breadcrumb-item"><a href="/disponibilidades">Disponibilidades</a></li>
            <li class="breadcrumb-item active"><a href="javascript:void(0)"><%= titulo %></a></li>
        </ol>
    </div>
</div>

<div class="row">
    <div class="col-lg-12">
        <div class="card">
            <div class="card-body">
                <form action="/disponibilidades/<%= disponibilidade && disponibilidade.id ? disponibilidade.id + '/editar' : 'criar' %>" method="POST">
                    <div class="form-group row">
                        <label class="col-sm-3 col-form-label">Professor</label>
                        <div class="col-sm-9">
                            <select class="form-control" name="professorId" required>
                                <option value="">Selecione...</option>
                                <% professores.forEach(p => { %>
                                    <option value="<%= p.id %>" <%= disponibilidade && disponibilidade.professor && disponibilidade.professor.id === p.id ? 'selected' : '' %>><%= p.nome %></option>
                                <% }) %>
                            </select>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-sm-3 col-form-label">Dia da Semana</label>
                        <div class="col-sm-9">
                            <select class="form-control" name="diaSemana" required>
                                <% ['Segunda','Terça','Quarta','Quinta','Sexta','Sábado','Domingo'].forEach(d => { %>
                                    <option value="<%= d %>" <%= disponibilidade && disponibilidade.diaSemana === d ? 'selected' : '' %>><%= d %></option>
                                <% }) %>
                            </select>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-sm-3 col-form-label">Horário Início</label>
                        <div class="col-sm-9">
                            <input type="time" class="form-control" name="horarioInicio" value="<%= disponibilidade ? disponibilidade.horarioInicio : '' %>" required>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-sm-3 col-form-label">Horário Fim</label>
                        <div class="col-sm-9">
                            <input type="time" class="form-control" name="horarioFim" value="<%= disponibilidade ? disponibilidade.horarioFim : '' %>" required>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-sm-3 col-form-label">Status</label>
                        <div class="col-sm-9">
                            <select class="form-control" name="statusDisp">
                                <% ['Disponível','Indisponível','Bloqueado'].forEach(s => { %>
                                    <option value="<%= s %>" <%= disponibilidade && disponibilidade.statusDisp === s ? 'selected' : '' %>><%= s %></option>
                                <% }) %>
                            </select>
                        </div>
                    </div>
                    <div class="form-group row">
                        <div class="col-sm-9 offset-sm-3">
                            <button type="submit" class="btn btn-primary">Salvar</button>
                            <a href="/disponibilidades" class="btn btn-light ml-2">Cancelar</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
