<div class="header">
    <div class="header-content">
        <nav class="navbar navbar-expand">
            <div class="collapse navbar-collapse justify-content-between">
                <% if (typeof headerType !== 'undefined' && headerType === 'escola') { %>
                <div class="header-left d-flex align-items-center w-100">
                    <h4 class="m-0 text-dark font-weight-bold ml-3"><i class="mdi mdi-domain mr-2 text-theme-primary"></i> Recursos e Configurações da Escola</h4>
                    
                    <div class="d-none d-xl-flex flex-grow-1 justify-content-end align-items-center mr-4">
                        <a href="/" class="btn btn-outline-light btn-icon text-theme-primary border mr-3"><i class="mdi mdi-home" style="font-size: 18px;"></i></a>
                    </div>
                <% } else if (typeof headerType !== 'undefined' && headerType === 'agenda') { %>
                <div class="header-left d-flex align-items-center w-100 px-3">
                    <h4 class="m-0 text-dark font-weight-bold d-flex align-items-center mr-4" style="font-size: 16px;">
                        <i class="mdi mdi-calendar text-theme-primary mr-2" style="font-size: 20px;"></i> Agenda
                    </h4>
                    
                    <button class="btn btn-theme-primary btn-sm mr-2"><i class="mdi mdi-tag"></i> Legenda / Opções</button>
                    <button class="btn btn-theme-primary btn-sm mr-4"><i class="mdi mdi-calendar-month"></i> Calendário</button>
                    
                    <div class="btn-group btn-group-toggle mr-3" data-toggle="buttons">
                        <label class="btn btn-sm <%= modoRecurso === 'professores' ? 'btn-primary text-white' : 'btn-outline-light text-muted border' %>" onclick="navigateAgenda('/agenda?recurso=professores&date=<%= dataInput %>&filtro=<%= modoFiltro %>')">
                            <input type="radio" name="recurso" id="professores" <%= modoRecurso === 'professores' ? 'checked' : '' %>> <i class="mdi <%= modoRecurso === 'professores' ? 'mdi-check-circle' : 'mdi-circle-outline' %> mr-1"></i> Professores
                        </label>
                        <label class="btn btn-sm <%= modoRecurso === 'salas' ? 'btn-primary text-white' : 'btn-outline-light text-muted border' %>" onclick="navigateAgenda('/agenda?recurso=salas&date=<%= dataInput %>&filtro=<%= modoFiltro %>')">
                            <input type="radio" name="recurso" id="salas" <%= modoRecurso === 'salas' ? 'checked' : '' %>> <i class="mdi <%= modoRecurso === 'salas' ? 'mdi-check-circle' : 'mdi-circle-outline' %> mr-1"></i> Salas
                        </label>
                    </div>

                    <div class="btn-group btn-group-toggle mr-auto" data-toggle="buttons">
                        <label class="btn btn-sm <%= modoFiltro === 'todos' ? 'btn-primary text-white' : 'btn-outline-light text-muted border' %>" onclick="navigateAgenda('/agenda?recurso=<%= modoRecurso %>&date=<%= dataInput %>&filtro=todos')">
                            <input type="radio" name="filtro" id="todos" <%= modoFiltro === 'todos' ? 'checked' : '' %>> <i class="mdi <%= modoFiltro === 'todos' ? 'mdi-check-circle' : 'mdi-circle-outline' %> mr-1"></i> Todos
                        </label>
                        <label class="btn btn-sm <%= modoFiltro === 'com-aula' ? 'btn-primary text-white' : 'btn-outline-light text-muted border' %>" onclick="navigateAgenda('/agenda?recurso=<%= modoRecurso %>&date=<%= dataInput %>&filtro=com-aula')">
                            <input type="radio" name="filtro" id="com-aula" <%= modoFiltro === 'com-aula' ? 'checked' : '' %>> <i class="mdi <%= modoFiltro === 'com-aula' ? 'mdi-check-circle' : 'mdi-circle-outline' %> mr-1"></i> Com aula
                        </label>
                    </div>
                    
                    <div class="d-flex align-items-center">
                        <div class="mr-2">
                            <input type="date" class="form-control text-theme-primary border" value="<%= dataInput %>" onchange="navigateAgenda('/agenda?recurso=<%= modoRecurso %>&filtro=<%= modoFiltro %>&date=' + this.value)" style="height: 33px; font-size: 13px; font-weight: bold; cursor: pointer; background-color: #fff; border-radius: 4px;">
                        </div>
                        <% datasRapidas.forEach((d, i) => { %>
                            <a href="javascript:void(0);" onclick="navigateAgenda('/agenda?recurso=<%= modoRecurso %>&filtro=<%= modoFiltro %>&date=<%= d.fullDate %>')" class="btn btn-sm mr-1 <%= i !== 1 ? 'btn-outline-light text-muted border' : 'btn-outline-primary text-theme-primary' %>" style="<%= i !== 1 ? 'background-color:#fff;' : 'background-color:rgba(108,92,231,0.05); border:1px solid rgba(108,92,231,0.2);' %>">
                                <strong><%= d.dia %></strong> <%= d.mes %> <%= d.ano %>
                            </a>
                        <% }) %>
                    </div>
                </div>
                <% } else { %>
                <div class="header-left d-flex align-items-center w-100">
                    <div class="header-search" style="position: relative;">
                        <i class="mdi mdi-magnify"></i>
                        <input class="form-control" type="text" placeholder="Pesquise aqui" id="searchPessoas" autocomplete="off">
                        <div id="searchResults" class="search-results-dropdown"></div>
                    </div>
                    
                    <div class="theme-top-tabs d-none d-xl-flex flex-grow-1 justify-content-center align-items-center">
                        <a href="/atendimento" class="btn btn-theme-primary mr-2"><i class="mdi mdi-account-tie"></i> Atendimento</a>
                        <a href="/agenda" class="btn btn-theme-primary mr-2"><i class="mdi mdi-calendar"></i> Agenda</a>
                        <a href="/escola" class="btn btn-theme-primary mr-2"><i class="mdi mdi-domain"></i> Escola</a>
                        <a href="/turmas" class="btn btn-theme-primary mr-2"><i class="mdi mdi-google-classroom"></i> Turmas</a>
                    </div>
                </div>
                <% } %>

                <ul class="navbar-nav header-right">
                    <!-- Notifications and Account removed as requested -->
                </ul>
            </div>
        </nav>
    </div>
</div>