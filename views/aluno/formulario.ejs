<div class="row page-titles mx-0">
    <div class="col-sm-6 p-md-0">
        <div class="welcome-text">
            <h4><%= titulo %></h4>
        </div>
    </div>
    <div class="col-sm-6 p-md-0 justify-content-sm-end mt-2 mt-sm-0 d-flex">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Inicial</a></li>
            <li class="breadcrumb-item"><a href="/alunos">Alunos</a></li>
            <li class="breadcrumb-item active"><a href="javascript:void(0)"><%= titulo %></a></li>
        </ol>
    </div>
</div>

<div class="row">
    <div class="col-lg-12">
        <div class="card">
            <div class="card-body">
                <form action="/alunos/<%= aluno && aluno.id ? aluno.id + '/editar' : 'criar' %>" method="POST">
                    <div class="form-group row">
                        <label class="col-sm-3 col-form-label">Nome</label>
                        <div class="col-sm-9">
                            <input type="text" class="form-control" name="nome" value="<%= aluno ? aluno.nome : '' %>" required>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-sm-3 col-form-label">CPF</label>
                        <div class="col-sm-9">
                            <input type="text" class="form-control" name="cpf" maxlength="11" value="<%= aluno ? aluno.cpf : '' %>" required>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-sm-3 col-form-label">RG</label>
                        <div class="col-sm-9">
                            <input type="text" class="form-control" name="rg" maxlength="20" value="<%= aluno ? aluno.rg : '' %>" required>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-sm-3 col-form-label">E-mail</label>
                        <div class="col-sm-9">
                            <input type="email" class="form-control" name="email" value="<%= aluno ? (aluno.email || '') : '' %>">
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-sm-3 col-form-label">Telefone</label>
                        <div class="col-sm-9">
                            <input type="text" class="form-control" name="telefone" value="<%= aluno ? (aluno.telefone || '') : '' %>">
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-sm-3 col-form-label">Data de Nascimento</label>
                        <div class="col-sm-9">
                            <input type="date" class="form-control" name="dataNascimento" value="<%= aluno ? aluno.dataNascimento : '' %>" required>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-sm-3 col-form-label">Responsável</label>
                        <div class="col-sm-9">
                            <select class="form-control" name="responsavelId" required>
                                <option value="">Selecione...</option>
                                <% responsaveis.forEach(r => { %>
                                    <option value="<%= r.id %>" <%= aluno && aluno.responsavel && aluno.responsavel.id === r.id ? 'selected' : '' %>><%= r.nome %></option>
                                <% }) %>
                            </select>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-sm-3 col-form-label">Data de Matrícula</label>
                        <div class="col-sm-9">
                            <input type="date" class="form-control" name="dataMatricula" value="<%= aluno ? aluno.dataMatricula : '' %>" required>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-sm-3 col-form-label">Status</label>
                        <div class="col-sm-9">
                            <select class="form-control" name="statusAluno">
                                <% ['Ativo','Inativo','Cancelado','Suspenso'].forEach(s => { %>
                                    <option value="<%= s %>" <%= aluno && aluno.statusAluno === s ? 'selected' : '' %>><%= s %></option>
                                <% }) %>
                            </select>
                        </div>
                    </div>
                    <div class="form-group row">
                        <div class="col-sm-9 offset-sm-3">
                            <button type="submit" class="btn btn-primary">Salvar</button>
                            <a href="/alunos" class="btn btn-light ml-2">Cancelar</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
